---
interface Props {
  photos: string[]
  basePath: string
}

const { photos, basePath } = Astro.props
---

<div class="photo-gallery">
  <div class="gallery-header">
    <span class="gallery-count">{photos.length} photos</span>
    <button class="gallery-download-all" data-base-path={basePath} data-photos={JSON.stringify(photos)}>
      Download All
    </button>
  </div>
  <ul class="gallery-list">
    {photos.map((photo, i) => (
      <li class="gallery-item">
        <div class="gallery-thumb-wrap">
          <img
            src={`${basePath}/${photo}`}
            alt={`Photo ${i + 1}`}
            loading="lazy"
            decoding="async"
            data-preview="true"
            class="gallery-thumb"
          />
        </div>
        <div class="gallery-item-info">
          <span class="gallery-item-name">{photo}</span>
          <a
            href={`${basePath}/${photo}`}
            download={photo}
            class="gallery-download-btn"
            aria-label={`Download ${photo}`}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </a>
        </div>
      </li>
    ))}
  </ul>
</div>

<script>
  function initGallery() {
    document.querySelectorAll('.gallery-download-all').forEach(btn => {
      btn.addEventListener('click', async () => {
        const basePath = btn.getAttribute('data-base-path') || ''
        const photos: string[] = JSON.parse(btn.getAttribute('data-photos') || '[]')

        for (const photo of photos) {
          const a = document.createElement('a')
          a.href = `${basePath}/${photo}`
          a.download = photo
          document.body.appendChild(a)
          a.click()
          document.body.removeChild(a)
          // Small delay to avoid browser blocking
          await new Promise(r => setTimeout(r, 100))
        }
      })
    })
  }
  document.addEventListener('astro:page-load', initGallery)
  initGallery()
</script>

<style>
  .photo-gallery {
    margin: 2em 0;
  }

  .gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1em;
    padding-bottom: 0.75em;
    border-bottom: 1px solid var(--border);
  }

  .gallery-count {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .gallery-download-all {
    font-size: 0.8125rem;
    padding: 0.35em 0.75em;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .gallery-download-all:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  .gallery-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .gallery-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 768px) {
    .gallery-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .gallery-item {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .gallery-item:hover {
    border-color: var(--text-secondary);
  }

  .gallery-thumb-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--code-bg);
  }

  .gallery-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    margin: 0 !important;
    max-height: none !important;
  }

  .gallery-item-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4em 0.6em;
    gap: 0.5em;
    border-top: 1px solid var(--border);
  }

  .gallery-item-name {
    font-size: 0.6875rem;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--font-mono, monospace);
  }

  .gallery-download-btn {
    flex-shrink: 0;
    color: var(--text-secondary);
    padding: 0.2em;
    border-radius: 3px;
    transition: color 0.15s;
    display: flex;
    align-items: center;
  }

  .gallery-download-btn:hover {
    color: var(--text-primary);
  }
</style>
