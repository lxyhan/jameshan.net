---
import { getCollection } from 'astro:content'

const allPosts = await getCollection('posts')

const featuredSlugs = [
  { slug: 'essays/shurik_gaidai_and_the_soviet_laugh', title: "Gaidai, Shurik, and 76 million tickets" },
  { slug: 'essays/a_farewell_to_arms_ernest_hemingway_1929', title: "A Farewell to Arms (Hemingway, 1929)" },
  { slug: 'essays/red_star_over_china_edgar_snow_1937', title: "Red Star Over China (Snow, 1937)" },
  { slug: 'essays/no_mans_land_and_the_comedy_of_observers', title: "No Man's Land and the Comedy of Observers" },
  { slug: 'essays/discontinuous_utility_and_the_jutland_paradox', title: "Discontinuous Utility and the Jutland Paradox" },
  { slug: 'essays/coordination_without_authority_zhang_zuolin_and_the_fengtian_clique', title: "The Old Marshal's coalition" },
  { slug: 'essays/in_the_heat_of_the_sun_memory_as_authorship', title: "In the Heat of the Sun: Memory as Authorship" },
  { slug: 'essays/andrei_rublev_and_the_problem_of_creation_under_uncertainty', title: "Andrei Rublev and the Problem of Creation" },
  { slug: 'essays/a_time_of_gifts_patrick_leigh_fermor_1977', title: "A Time of Gifts (Fermor, 1977)" },
  { slug: 'essays/bridging_the_transit_data_gap', title: "ML for Latent Transit Demand Detection in Unserved Communities" },
]

const featured = featuredSlugs.map(({ slug, title }) => {
  const post = allPosts.find(p => p.id === slug)
  const date = post?.data.pubDate
  const formatted = date
    ? `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`
    : ''
  return { title, href: `/${slug}`, date: formatted, raw: date }
}).filter(e => e.date).sort((a, b) => b.raw!.getTime() - a.raw!.getTime())
---

<div class="recent-writing">
  <div class="label">Notes, essays, thoughts</div>
  <ul>
    {featured.map(essay => (
      <li>
        <a href={essay.href}>{essay.title}</a>
        <span class="date">{essay.date}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .recent-writing {
    margin-top: 1.5rem;
    font-size: 0.9rem;
  }

  .label {
    color: var(--text-primary);
    font-size: 0.85rem;
    font-weight: 700;
    padding-bottom: 0.4rem;
    margin-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    line-height: 1.8;
  }

  li a {
    color: var(--text-primary);
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
  }

  .date {
    color: var(--text-primary);
    font-size: 0.82rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
