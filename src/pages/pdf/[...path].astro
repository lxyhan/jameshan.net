---
import fs from 'node:fs'
import path from 'node:path'
import BaseLayout from '@/layouts/BaseLayout.astro'
import BaseHead from '@/components/layout/BaseHead.astro'
import Breadcrumb from '@/components/ui/Breadcrumb.astro'
import { themeConfig } from '@/config'

export function getStaticPaths() {
  const pdfRoot = path.join(process.cwd(), 'public', 'pdfs')

  function findPdfs(dir: string, base = ''): string[] {
    const results: string[] = []
    if (!fs.existsSync(dir)) return results
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      const rel = base ? `${base}/${entry.name}` : entry.name
      if (entry.isDirectory()) results.push(...findPdfs(path.join(dir, entry.name), rel))
      else if (entry.name.endsWith('.pdf')) results.push(rel)
    }
    return results
  }

  return findPdfs(pdfRoot).map((pdfPath) => {
    const filename = pdfPath.split('/').pop()!
    const displayName = filename.replace(/\.pdf$/i, '').replace(/[-_]/g, ' ')
    return {
      params: { path: pdfPath },
      props: { pdfPath, displayName, pdfUrl: `/pdfs/${pdfPath}` },
    }
  })
}

const { pdfPath, displayName, pdfUrl } = Astro.props
---

<BaseLayout type="post" blogTreeFirst={true}>
  <BaseHead
    title={`${displayName} · ${themeConfig.site.title}`}
    description={displayName}
    slot="head"
  />
  <div class="pdf-container">
    <main>
      <div class="pdf-header">
        <h1 class="pdf-title">{displayName}</h1>
        <a href={pdfUrl} class="pdf-download" download>Download PDF</a>
      </div>
      <div class="pdf-embed">
        <iframe src={pdfUrl} width="100%" height="100%" title={displayName}></iframe>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .pdf-container {
    display: flex;
    flex-direction: column;
    flex: 1;
    height: 100%;
  }

  .pdf-container main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .pdf-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
  }

  .pdf-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }

  .pdf-download {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    white-space: nowrap;
  }

  .pdf-download:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
  }

  .pdf-embed {
    flex: 1;
    min-height: 85vh;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .pdf-embed iframe {
    display: block;
    border: none;
  }
</style>
