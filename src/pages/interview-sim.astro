---
import IndexLayout from '@/layouts/IndexLayout.astro'
import JobBoard from '@/components/react-practice/interview-sims/JobBoard'
import DayCalendar from '@/components/react-practice/interview-sims/DayCalendar'
import Spreadsheet from '@/components/react-practice/interview-sims/Spreadsheet'
import DynamicDisplayDemo from '@/components/react-practice/interview-sims/DynamicDisplay'
import TransactionLedger from '@/components/react-practice/interview-sims/TransactionLedger'
import UserDirectory from '@/components/react-practice/interview-sims/Calendaar'
---

<IndexLayout title="Interview Sim" description="Ramp-style live coding challenges">
  <div class="sim-container">
    <h1>Interview Simulations</h1>

    <section>
      <h3>Challenge 1: Master-Detail Job Board</h3>
      <JobBoard client:load />
    </section>

    <section>
      <h3>Challenge 2: Single-Day Calendar</h3>
      <DayCalendar client:load />
    </section>

    <section>
      <h3>Challenge 3: Mini Spreadsheet</h3>
      <Spreadsheet client:load />
    </section>

    <section>
      <h3>Challenge 4: Dynamic Prop Component</h3>
      <DynamicDisplayDemo client:load />
    </section>

    <section>
      <h3>Challenge 5: Transaction Ledger</h3>
      <TransactionLedger client:load />
    </section>

    <section>
      <h3>Challenge 6: User Directory with Tabs</h3>
      <UserDirectory client:load />
    </section>
  </div>
</IndexLayout>

<style>
  .sim-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  section {
    margin-bottom: 3rem;
    padding: 1.5rem;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
  }
  h1 {
    margin-bottom: 2rem;
  }
  h3 {
    margin-bottom: 1rem;
  }
</style>
