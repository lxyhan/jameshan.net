---
import IndexLayout from '@/layouts/IndexLayout.astro'
import ProfileCard from '@/components/react-practice/ProfileCard'
import TodoList from '@/components/react-practice/TodoList'
import ThemeSwitcher from '@/components/react-practice/ThemeSwitcher'
import GithubRepos from '@/components/react-practice/GithubRepos'
import TechSearch from '@/components/react-practice/TechSearch'
import ContactForm from '@/components/react-practice/ContactForm'
import ExpenseTracker from '@/components/react-practice/ExpenseTracker'
---

<IndexLayout title="React Practice" description="Learning React fundamentals">
  <div class="practice-container">
    <h1>React Practice Components</h1>

    <h2 class="section-header">Quick Start</h2>

    <section>
      <h3>1. ProfileCard</h3>
      <ProfileCard client:load />
    </section>

    <section>
      <h3>2. TodoList</h3>
      <TodoList client:load />
    </section>

    <section>
      <h3>3. ThemeSwitcher</h3>
      <ThemeSwitcher client:load />
    </section>

    <h2 class="section-header">Intermediate</h2>

    <section>
      <h3>4. GithubRepos</h3>
      <GithubRepos client:load />
    </section>

    <section>
      <h3>5. TechSearch</h3>
      <TechSearch client:load />
    </section>

    <section>
      <h3>6. ContactForm</h3>
      <ContactForm client:load />
    </section>

    <h2 class="section-header">Capstone</h2>

    <section>
      <h3>7. Expense Tracker</h3>
      <ExpenseTracker client:load />
    </section>
  </div>
</IndexLayout>

<style>
  .practice-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .section-header {
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #333;
  }
  section {
    margin-bottom: 3rem;
    padding: 1.5rem;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
  }
  h1 {
    margin-bottom: 2rem;
  }
  h3 {
    margin-bottom: 1rem;
  }
</style>
